# ─────────────────────────────────────────────────────────────
# Web2Print — Environment Variables (TEMPLATE)
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — NEVER commit real secrets.
# In production (e.g. Vercel), set these in the project's
# Environment Variables settings, not in a file.
#
# Keys WITHOUT the NEXT_PUBLIC_ prefix are server-only (safe).
# NEVER put a secret behind NEXT_PUBLIC_ — it gets exposed to the browser.
# ─────────────────────────────────────────────────────────────

# ── 4over (print provider) ──────────────────────────────────
# Server-only. Get these from your 4over API account.
FOUROVER_PUBLIC_KEY=
FOUROVER_API_SECRET=
FOUROVER_API_URL=https://api.4over.com

# ── SS Activewear (apparel inventory) ───────────────────────
# Server-only. Used to download their inventory. (Fill in when set up.)
SSACTIVEWEAR_ACCOUNT_NUMBER=
SSACTIVEWEAR_API_KEY=

# ── Supabase (database + auth) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses Row Level Security. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (payments) ───────────────────────────────────────
# Publishable key is safe for the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-only — keep secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── CRM (GoHighLevel) ────────────────────────────────────────
# Server-only. Inbound Webhook URL from a GHL Workflow — fires on every
# new customer signup with name/email/phone.
GHL_WEBHOOK_URL=
